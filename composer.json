{
    "name": "dept-of-scrapyard-robotics/ssd1306",
    "description": "ScrapyardIO Framework extension library that enables I2C and SPI Control of SSD1306 Monochrome Displays on Linux",
    "type": "library",
    "version": "0.2.0",
    "keywords": [
        "laravel",
        "io",
        "linux",
        "embedded",
        "spi",
        "i2c",
        "ssd1306"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Project Saturn Studios, LLC",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",

        "dept-of-scrapyard-robotics/displays": "^0.2.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "*",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "ScrapyardIO\\Libraries\\Displays\\Drivers\\SSD1306\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "minimum-stability": "stable"
}
